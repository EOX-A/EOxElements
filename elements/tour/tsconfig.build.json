{
  "compilerOptions": {
    "moduleResolution": "bundler",
    "noEmit": false,
    "baseUrl": ".",
    "jsx": "react",
    "typeRoots": {
      "@eox/*": ["../*/src"]
    },
    "allowJs": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "./types",
    "rootDir": "src",
    "paths": {}
  },
  "include": ["src/**/*"]
}
