{
  "name": "@eox/elements",
  "homepage": "https://eox-a.github.io/EOxElements",
  "private": true,
  "type": "module",
  "version": "2.0.0",
  "workspaces": [
    "elements/*",
    "utils",
    "mcp-server"
  ],
  "scripts": {
    "start": "pnpm run generate-typedoc && pnpm run generate-snippets && pnpm run generate-llms && pnpm run \"/^(watch:|storybook$)/\"",
    "watch:styles": "nodemon --watch ./utils/styles --ext css --exec 'pnpm run styles'",
    "styles": "node ./tasks/init-style.js",
    "build:all": "pnpm run styles && pnpm -r run build",
    "clean": "pnpm -r exec rimraf node_modules && pnpm -r exec rimraf types && rimraf node_modules",
    "cypress": "cypress open",
    "cypress:install": "cypress install",
    "test:all": "pnpm run styles && pnpm run test:component; pnpm run test:e2e",
    "test:component": "pnpm run styles && cypress run --component",
    "test:e2e": "pnpm run generate-manifest && pnpm run generate-typedoc && pnpm -r --if-present run build:element-story-bundle && pnpm run build:storybook && cypress run --e2e",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint elements",
    "lint:fix": "eslint elements --fix",
    "typecheck": "tsc",
    "types:generate:all": "pnpm -r --if-present run types:generate",
    "storybook": "storybook dev -p 6006",
    "build:docs": "pnpm run styles && pnpm -r --if-present run build:element-story-bundle && pnpm run generate-manifest && pnpm run generate-typedoc && pnpm run generate-snippets && pnpm run generate-llms && pnpm run build:storybook && cp custom-elements.json docs/custom-elements.json && cp story-snippets.json docs/story-snippets.json && cp llms.txt docs/llms.txt && cp llms-full.txt docs/llms-full.txt",
    "build:storybook": "storybook build -o docs",
    "generate-snippets": "node --loader ./scripts/loader.mjs scripts/generate-snippets.mjs",
    "generate-llms": "node scripts/generate-llms-txt.mjs",
    "generate-manifest": "pnpm exec custom-elements-manifest analyze --litelement",
    "watch:generate-manifest": "pnpm exec custom-elements-manifest analyze --litelement --watch",
    "generate-typedoc": "rm -f ./types.json && pnpm exec typedoc",
    "nyc:report": "nyc report --reporter=text-summary"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@cypress/code-coverage": "^4.0.0",
    "@cypress/mount-utils": "^4.0.0",
    "@eox/chart": "workspace:*",
    "@eox/drawtools": "workspace:*",
    "@eox/eslint-config": "^2.0.0",
    "@eox/feedback": "workspace:*",
    "@eox/geosearch": "workspace:*",
    "@eox/itemfilter": "workspace:*",
    "@eox/jsonform": "workspace:*",
    "@eox/layercontrol": "workspace:*",
    "@eox/layout": "workspace:*",
    "@eox/map": "workspace:*",
    "@eox/stacinfo": "workspace:*",
    "@eox/storytelling": "workspace:*",
    "@eox/timecontrol": "workspace:*",
    "@eox/tour": "workspace:*",
    "@storybook/addon-docs": "^10.0.8",
    "@storybook/web-components-vite": "^10.0.8",
    "custom-elements-manifest": "^2.0.0",
    "cypress": "^15.0.0",
    "cypress-fail-on-console-error": "^5.1.1",
    "cypress-file-upload": "^5.0.8",
    "cypress-lit": "^0.0.8",
    "cypress-network-idle": "^2.0.1",
    "eslint-plugin-storybook": "^10.0.8",
    "nodemon": "^3.0.3",
    "nyc": "^18.0.0",
    "prettier-plugin-svelte": "^3.4.0",
    "rimraf": "^6.0.1",
    "serialize-javascript": "^7.0.0",
    "storybook": "^10.0.8",
    "typedoc": "^0.28.14",
    "typedoc-plugin-markdown": "^4.9.0",
    "typedoc-plugin-merge-modules": "^7.0.0",
    "typescript-json-schema": "^0.67.2",
    "vite-plugin-istanbul": "^8.0.0"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@eox/elements-utils": "^1.1.0",
    "@eox/ui": "^1.0.0"
  },
  "customElements": "custom-elements.json"
}
